// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String?
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SliderImage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  url       String
  publicId  String   @unique
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  lot       String   @default("A") // To differentiate between lots if needed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GlobalSettings {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model ParkingLot {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  capacity      Int
  address       String
  latitude      Float?
  longitude     Float?
  
  // Rates
  halfHourRate  Float    @default(0)
  hourlyRate    Float    @default(0)
  dailyRate     Float    @default(0)
  weeklyRate    Float    @default(0)
  monthlyRate   Float    @default(0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  bookings      Booking[]
}

model LandlordProposal {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  lotName              String
  address              String
  latitude             Float?
  longitude            Float?
  spots                Int
  perSpotPriceMonthly  Float
  masterLeasePrice     Float
  yearlyLease          Float?
  parcelAddress        String?
  parcelId             String?
  ownerName            String?
  ownerMailingAddress  String?
  ownerContact         String?
  thumbnail            String?
  images               String[] @default([])
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Booking {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  lotId         String   @db.ObjectId
  lot           ParkingLot @relation(fields: [lotId], references: [id])
  carNumber     String
  phoneNumber   String
  countryCode   String
  slotNumber    Int?     // New field for slot selection
  durationMode  String   // half, hourly, daily, weekly, monthly
  durationValue Float
  totalPrice    Float
  notificationSent Boolean @default(false)
  
  // Payment Fields
  paymentStatus     String   @default("pending")  // pending, completed, failed, canceled
  paymentIntentId   String?  // Removed @unique - validation handled in code
  paymentMethod     String?  @default("stripe")
  paidAt            DateTime?
  paymentFailureReason String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  smsLogs       SmsLog[]
  
  @@index([paymentIntentId])
}

model SmsLog {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  bookingId       String   @db.ObjectId
  phone           String
  messageSid      String   @unique
  deliveryStatus  String   @default("queued") // queued, sent, delivered, failed
  timestamp       DateTime @default(now())
  
  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

// 🔥 Enterprise Payment Transaction Log - Audit trail for all payments
model PaymentTransaction {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  
  // Stripe Payment Details
  paymentIntentId   String   @unique
  stripeCustomerId  String?
  chargeId          String?
  
  // Booking Reference
  bookingId         String?  @db.ObjectId
  
  // Transaction Details
  amount            Int      // Amount in cents
  currency          String   @default("usd")
  status            String   // pending, succeeded, failed, canceled, fraud_suspected
  
  // Metadata for fraud verification
  vehicleNumber     String?
  lotId             String?
  slotNumber        Int?
  phoneNumber       String?
  
  // Error tracking
  errorCode         String?
  errorMessage      String?
  
  // IP and device tracking (optional fraud prevention)
  ipAddress         String?
  userAgent         String?
  
  // Timestamps
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([bookingId])
  @@index([status])
  @@index([createdAt])
}
